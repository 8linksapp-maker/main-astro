---
/**
 * admin/leads.astro
 *
 * Página de listagem de leads no painel administrativo.
 * Exibe todos os leads gerados pelos formulários do site (contato, local-contato, servico-sidebar).
 * Dados carregados via fetch em /api/admin/leads (client-side).
 */

import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Leads - CNX Agency Admin">
    <div class="space-y-6">
        <!-- Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-heading font-bold text-[#e5e5e5] mb-2">
                    Leads
                </h1>
                <p class="text-[#a3a3a3]">
                    Todos os leads gerados pelos formulários do site
                </p>
            </div>
        </div>

        <!-- Loading -->
        <div id="leads-loading" class="admin-card p-12 text-center text-[#a3a3a3]">
            Carregando leads...
        </div>

        <!-- Empty state -->
        <div id="leads-empty" class="admin-card p-12 text-center text-[#a3a3a3]" style="display: none;">
            Nenhum lead encontrado. Os formulários de contato do site aparecerão aqui quando forem preenchidos.
        </div>

        <!-- Table -->
        <div id="leads-table-wrap" class="admin-card overflow-hidden p-0" style="display: none;">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-[#111111] border-b border-[rgba(255,255,255,0.08)]">
                        <tr>
                            <th class="px-6 py-4 text-left text-sm font-semibold text-[#a3a3a3]">Data</th>
                            <th class="px-6 py-4 text-left text-sm font-semibold text-[#a3a3a3]">Nome</th>
                            <th class="px-6 py-4 text-left text-sm font-semibold text-[#a3a3a3]">Contato</th>
                            <th class="px-6 py-4 text-left text-sm font-semibold text-[#a3a3a3]">Origem</th>
                            <th class="px-6 py-4 text-left text-sm font-semibold text-[#a3a3a3]">Mensagem</th>
                        </tr>
                    </thead>
                    <tbody id="leads-tbody" class="divide-y divide-[rgba(255,255,255,0.08)]">
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Error state -->
        <div id="leads-error" class="admin-card p-6 border border-red-500/30 bg-red-500/5" style="display: none;">
            <p class="text-red-400 font-medium">Erro ao carregar leads</p>
            <p id="leads-error-msg" class="text-[#a3a3a3] text-sm mt-1"></p>
        </div>
    </div>
</AdminLayout>

<script>
    (function() {
        const loading = document.getElementById('leads-loading');
        const empty = document.getElementById('leads-empty');
        const tableWrap = document.getElementById('leads-table-wrap');
        const tbody = document.getElementById('leads-tbody');
        const errorEl = document.getElementById('leads-error');
        const errorMsg = document.getElementById('leads-error-msg');

        function formatDate(iso) {
            try {
                const d = new Date(iso);
                return d.toLocaleDateString('pt-BR', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                });
            } catch {
                return iso;
            }
        }

        function sourceLabel(source) {
            const labels = {
                'contato': 'Contato (Classic)',
                'local-contato': 'Contato (Local)',
                'servico-sidebar': 'Sidebar Serviço',
            };
            return labels[source] || source;
        }

        async function loadLeads() {
            try {
                const res = await fetch('/api/admin/leads');
                const data = await res.json();

                if (loading) loading.style.display = 'none';

                if (!res.ok) {
                    if (errorEl && errorMsg) {
                        errorMsg.textContent = data.error || 'Erro desconhecido';
                        errorEl.style.display = 'block';
                    }
                    return;
                }

                const leads = data.leads || [];

                if (leads.length === 0) {
                    if (empty) empty.style.display = 'block';
                    return;
                }

                if (tableWrap && tbody) {
                    tableWrap.style.display = 'block';
                    tbody.innerHTML = leads.map((l) => {
                        const contact = [l.email, l.phone].filter(Boolean).join(' · ') || '-';
                        const msg = (l.message || '').length > 80
                            ? (l.message || '').slice(0, 80) + '…'
                            : (l.message || '-');
                        return `
                            <tr class="hover:bg-[#111111] transition-colors">
                                <td class="px-6 py-4 text-sm text-[#a3a3a3] whitespace-nowrap">${formatDate(l.createdAt || '')}</td>
                                <td class="px-6 py-4 font-medium text-[#e5e5e5]">${escapeHtml(l.name || '-')}</td>
                                <td class="px-6 py-4 text-sm text-[#a3a3a3]">${escapeHtml(contact)}</td>
                                <td class="px-6 py-4 text-sm text-[#a3a3a3]">${sourceLabel(l.source || '')}</td>
                                <td class="px-6 py-4 text-sm text-[#a3a3a3] max-w-xs truncate" title="${escapeAttr(l.message || '')}">${escapeHtml(msg)}</td>
                            </tr>
                        `;
                    }).join('');
                }
            } catch (e) {
                if (loading) loading.style.display = 'none';
                if (errorEl && errorMsg) {
                    errorMsg.textContent = String(e);
                    errorEl.style.display = 'block';
                }
                console.error('\x1b[31m✗ Erro ao carregar leads:\x1b[0m', e);
            }
        }

        function escapeHtml(s) {
            const div = document.createElement('div');
            div.textContent = s;
            return div.innerHTML;
        }

        function escapeAttr(s) {
            return s.replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        document.addEventListener('DOMContentLoaded', loadLeads);
    })();
</script>
