---
import CmsLayout from '../../../../../layouts/CmsLayout.astro';
import { supabaseSSR } from '../../../../../lib/supabaseSSR';
import CategoriesEditor from '../../../../../components/admin/cms/CategoriesEditor.tsx';

const { id } = Astro.params;
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: site, error: siteError } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('id', id)
    .single();

if (!site || siteError) {
    return Astro.redirect('/dashboard/cms');
}
---

<CmsLayout title={`Categorias: ${site.company_name} | CMS`} siteId={id} siteName={site.company_name} repoName={site.repo_name}>
    
    <div class="mb-12 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 bg-white p-8 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden">
        <div class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-50 rounded-full blur-3xl"></div>
        <div class="relative z-10">
            <h2 class="text-2xl font-black text-slate-900 mb-2">
                Gerenciar <span class="text-indigo-600">Categorias</span>
            </h2>
            <p class="text-slate-500 font-medium">Defina as taxonomias que serão usadas para organizar seus artigos do blog.</p>
        </div>
    </div>

    <CategoriesEditor client:load siteId={id as string} repoName={site.repo_name} />

</CmsLayout>
