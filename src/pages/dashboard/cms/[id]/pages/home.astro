---
import CmsFullscreenLayout from '../../../../../layouts/CmsFullscreenLayout.astro';
import { supabaseSSR } from '../../../../../lib/supabaseSSR';
import HomeEditor from '../../../../../components/admin/cms/HomeEditor.tsx';

const { id } = Astro.params;
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: site, error: siteError } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('id', id)
    .single();

if (!site || siteError) {
    return Astro.redirect('/dashboard/cms');
}
---

<CmsFullscreenLayout title={`Editor: ${site.company_name} | CMS`}>
    <div class="w-full relative px-4 sm:px-8 pt-8">
        <HomeEditor client:load siteId={id as string} repoName={site.repo_name} siteUrl={site.url} />
    </div>
</CmsFullscreenLayout>
