---
import CmsLayout from '../../../../layouts/CmsLayout.astro';
import { supabaseSSR } from '../../../../lib/supabaseSSR';
import ConfigEditor from '../../../../components/admin/cms/ConfigEditor.tsx';

const { id } = Astro.params;
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

// Resgatar Infos para Header e Propriedades
const { data: site, error: siteError } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('id', id)
    .single();

if (!site || siteError) {
    return Astro.redirect('/dashboard/cms');
}
---

<CmsLayout title={`Configurações: ${site.company_name} | CMS`} siteId={id as string} siteName={site.company_name} repoName={site.repo_name}>
    <div class="mb-10">
        <h2 class="text-3xl font-black text-slate-900 mb-3 tracking-tight">Configurações Globais</h2>
        <p class="text-slate-500 font-medium text-lg leading-relaxed max-w-2xl">
            Edite a identidade viva do seu Site. O título principal, links das redes sociais no rodapé, endereço e e-mails de contato da empresa e paleta de cores inteira.
        </p>
    </div>

    <!-- O Editor Interativo em React que falará com a API GitBehind -->
    <ConfigEditor client:load siteId={id as string} repoName={site.repo_name} />
</CmsLayout>
