---
import CmsFullscreenLayout from '../../../../../layouts/CmsFullscreenLayout.astro';
import { supabaseSSR } from '../../../../../lib/supabaseSSR';
import PostEditor from '../../../../../components/admin/cms/PostEditor.tsx';

const { id } = Astro.params;
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: site, error: siteError } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('id', id)
    .single();

if (!site || siteError) {
    return Astro.redirect('/dashboard/cms');
}

// Pegar Path (caso seja EDIÇÃO)
const path = Astro.url.searchParams.get('path');
---

<CmsFullscreenLayout title={`Redigir | CMS CNX`}>
    <div class="w-full relative px-4 sm:px-8">
        <PostEditor client:load siteId={id as string} repoName={site.repo_name} filePath={path} />
    </div>
</CmsFullscreenLayout>
