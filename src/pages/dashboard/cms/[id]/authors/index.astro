---
import CmsLayout from '../../../../../layouts/CmsLayout.astro';
import { supabaseSSR } from '../../../../../lib/supabaseSSR';
import AuthorsEditor from '../../../../../components/admin/cms/AuthorsEditor.tsx';

const { id } = Astro.params;
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: site, error: siteError } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('id', id)
    .single();

if (!site || siteError) {
    return Astro.redirect('/dashboard/cms');
}
---

<CmsLayout title={`Autores: ${site.company_name} | CMS`} siteId={id as string} siteName={site.company_name} repoName={site.repo_name}>
    <div class="mb-10">
        <h2 class="text-3xl font-black text-slate-900 mb-3 tracking-tight">Equipe Editora</h2>
        <p class="text-slate-500 font-medium text-lg leading-relaxed max-w-2xl">
            Gerencie os profissionais que produzem conteúdo para o seu site. Essa lista será carregada quando você for assinar a autoria de um novo Artigo.
        </p>
    </div>

    <AuthorsEditor client:load siteId={id as string} repoName={site.repo_name} />
</CmsLayout>
