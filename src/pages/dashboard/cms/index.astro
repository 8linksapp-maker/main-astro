---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabaseSSR } from '../../../lib/supabaseSSR';

const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

// Buscar sites gerados via Gerador Astro
const { data: sites, error } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false });

---

<DashboardLayout title="Meus Projetos IA (CMS) | CNX">
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-slate-200 pb-6">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 mb-2 flex items-center gap-3">
                <span class="text-3xl">✨</span> Meus Projetos IA
            </h2>
            <p class="text-slate-600">Gerencie e edite o conteúdo dos sites gerados por nossa inteligência artificial.</p>
        </div>
        <a href="/dashboard/cms/new" class="px-5 py-2.5 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors shadow-md shadow-violet-500/20 flex items-center gap-2 w-max">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            Criar Novo Site
        </a>
    </div>

    {error && (
        <div class="mb-8 bg-red-50 border border-red-200 rounded-2xl p-6 text-red-700">
            <h3 class="font-bold text-lg mb-2">Erro ao carregar sites</h3>
            <p>{error.message}</p>
        </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {!sites || sites.length === 0 ? (
            <div class="col-span-full bg-slate-50 rounded-2xl border border-dashed border-slate-300 p-12 text-center">
                <span class="text-4xl block mb-4">🏜️</span>
                <h3 class="text-xl font-bold text-slate-800 mb-2">Nenhum site no CMS</h3>
                <p class="text-slate-500 font-medium mb-6">Parece que você ainda não gerou nenhum site ou a tabela ainda não foi populada.</p>
                <a href="/dashboard/cms/new" class="inline-block px-6 py-3 bg-violet-600 text-white font-bold rounded-xl hover:bg-violet-700 transition-colors shadow-sm gap-2">
                    Gerar Meu Primeiro Site
                </a>
            </div>
        ) : (
            sites.map((site) => (
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col group hover:shadow-lg transition-all border-b-4 border-b-transparent hover:border-b-violet-500">
                    <div class="p-6 flex-1">
                        <div class="flex items-start justify-between mb-4">
                            <div class="w-12 h-12 bg-violet-100 rounded-xl flex items-center justify-center text-violet-600 font-bold text-xl uppercase">
                                {site.company_name?.charAt(0) || 'S'}
                            </div>
                            <span class={`px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ${
                                site.status === 'published' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700'
                            }`}>
                                {site.status}
                            </span>
                        </div>
                        
                        <h4 class="text-xl font-bold text-slate-900 mb-1 group-hover:text-violet-600 transition-colors">
                            {site.company_name}
                        </h4>
                        <p class="text-sm text-slate-500 mb-4 font-mono truncate">{site.repo_name}</p>
                        
                        <div class="flex items-center gap-2 text-xs text-slate-400 font-medium">
                            <span class="uppercase">{site.site_type}</span>
                            <span>•</span>
                            <span>Criado em {new Date(site.created_at).toLocaleDateString()}</span>
                        </div>
                    </div>
                    
                    <div class="p-4 bg-slate-50 border-t border-slate-100 flex items-center justify-between gap-2">
                        <a href={site.url} target="_blank" class="text-xs font-bold text-slate-600 hover:text-slate-900 transition-colors flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                              <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                              <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                            </svg>
                            Ver Site
                        </a>
                        <a href={`/dashboard/cms/${site.id}`} class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-bold text-violet-600 hover:bg-violet-600 hover:text-white transition-all shadow-sm">
                            Editar Conteúdo
                        </a>
                    </div>
                </div>
            ))
        )}
    </div>
</DashboardLayout>
