---
/**
 * CmsFullscreenLayout.astro
 * Layout isolado e 100% livre de distrações (sem sidebars)
 * Utilizado primariamente durante a edição massiva de Posts ou Pages
 */
import '../styles/global.css';
import CmsToaster from '../components/admin/cms/CmsToaster.tsx';

interface Props {
    title?: string;
}

const { title = "Editor | CMS CNX" } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
</head>
<body class="bg-[#f1f5f9] text-slate-900 font-sans min-h-screen">
    
    <!-- Canvas 100% Full Width Focus -->
    <main class="w-full min-h-screen">
        <slot />
    </main>

    <!-- CNX Global Modals & Toasts UI (Essencial para as fitas verdes de sucesso) -->
    <CmsToaster client:load />
    
</body>
</html>
