---
import siteConfig from '../../data/siteConfig.json';
---

<footer class="bg-[#050505] border-t border-white/[0.05] pt-20 pb-10 relative overflow-hidden">
  <!-- Subtle Glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[300px] bg-primary-600/10 rounded-[100%] blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-2">
        <a href="/" class="flex text-2xl font-bold text-white mb-6 block">
          {siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} class="h-8 w-auto object-contain filter brightness-0 invert opacity-90 transition-opacity hover:opacity-100" />
          ) : (
            siteConfig.name
          )}
        </a>
        <p class="text-slate-400 max-w-sm leading-relaxed font-light">
          {siteConfig.description}
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-6 tracking-wide">Navegação</h4>
        <ul class="space-y-4 text-slate-400 text-sm font-light">
          <li><a href="/" class="hover:text-primary-400 transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-primary-400 transition-colors">Artigos & Insights</a></li>
          <li><a href="/sobre" class="hover:text-primary-400 transition-colors">Sobre Nós</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-white mb-6 tracking-wide">Legal</h4>
        <ul class="space-y-4 text-slate-400 text-sm font-light">
          <li><a href="/termos" class="hover:text-primary-400 transition-colors">Termos de Uso</a></li>
          <li><a href="/privacidade" class="hover:text-primary-400 transition-colors">Política de Privacidade</a></li>
          <li><a href="/contato" class="hover:text-primary-400 transition-colors">Página de Contato</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/[0.05] flex flex-col md:flex-row justify-between items-center gap-6 text-slate-500 text-xs font-light tracking-wide">
      <p>&copy; {new Date().getFullYear()} {siteConfig.author}. Todos os direitos reservados.</p>
      <div class="flex gap-6">
        {siteConfig.social?.instagram && <a href={siteConfig.social.instagram} target="_blank" rel="noopener" class="hover:text-white transition-colors">Instagram</a>}
        {siteConfig.social?.facebook && <a href={siteConfig.social.facebook} target="_blank" rel="noopener" class="hover:text-white transition-colors">Facebook</a>}
        {siteConfig.social?.twitter && <a href={siteConfig.social.twitter} target="_blank" rel="noopener" class="hover:text-white transition-colors">Twitter</a>}
        {siteConfig.social?.linkedin && <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="hover:text-white transition-colors">LinkedIn</a>}
        {siteConfig.social?.github && <a href={siteConfig.social.github} target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>}
      </div>
    </div>
  </div>
</footer>
