---
import siteConfig from '../../data/siteConfig.json';
import categoriesData from '../../data/categories.json';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const categoriesFromPosts = [...new Set(posts.map(post => post.data.category).filter(Boolean))];

// Garantir que categoriesData seja um array
const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];

// Prioriza o categories.json, mas mantém compatibilidade com posts antigos se estiver vazio
const allCategories = finalCategoriesData.length > 0 ? finalCategoriesData : categoriesFromPosts;
---

<header class="fixed top-6 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-5xl z-50">
  <nav class="bg-black/40 backdrop-blur-2xl border border-white/10 rounded-full px-6 h-16 flex items-center justify-between shadow-2xl shadow-black/50">
    <a href="/" class="flex items-center gap-2 text-xl font-bold">
      {siteConfig.logo ? (
        <img src={siteConfig.logo} alt={siteConfig.name} class="h-8 w-auto object-contain filter brightness-0 invert" />
      ) : (
        <span class="text-white tracking-tight">{siteConfig.name}</span>
      )}
    </a>

    <div class="hidden md:flex items-center gap-8 bg-white/[0.03] px-8 h-full border-x border-white/5">
      <a href="/" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">Home</a>
      
      <div class="relative group h-full flex items-center">
        <a href="/blog" class="text-sm font-medium text-slate-300 hover:text-white transition-colors flex items-center gap-1 cursor-pointer">
          Blog
          <svg class="w-3 h-3 text-slate-500 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </a>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
          <div class="bg-[#111111] rounded-2xl shadow-2xl border border-white/10 flex flex-col py-2 overflow-hidden">
            <a href="/blog" class="px-5 py-2.5 text-sm text-white font-semibold hover:bg-white/[0.03] border-b border-white/5 transition-colors">Todos os Artigos</a>
            {allCategories.map((cat) => (
               <a href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} class="px-5 py-2.5 text-sm text-slate-400 hover:text-white hover:bg-white/[0.03] transition-colors">{cat}</a>
            ))}
          </div>
        </div>
      </div>
      <a href="/sobre" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">Sobre</a>
      <a href="/contato" class="text-sm font-medium text-slate-300 hover:text-white transition-colors">Contato</a>
    </div>

    <div class="flex items-center gap-4">
      <a href="/contato" class="hidden sm:inline-flex items-center justify-center px-6 py-2 rounded-full bg-white text-black text-sm font-bold hover:scale-105 transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)]">
        Falar Conosco
      </a>
      <!-- Mobile Menu Button -->
      <button class="md:hidden p-2 text-white/70 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </nav>
</header>
