---
interface Differentiator {
  title: string;
  desc: string;
}

interface Props {
  title: string;
  image: string;
  badgeText?: string;
  badgeColor?: string;
  items: Differentiator[];
}

const { title, image, items, badgeText = 'Garantia de Qualidade CNX', badgeColor = '#dbeafe' } = Astro.props;
---

<section class="py-32 px-4 bg-[#050505] relative overflow-hidden border-t border-white/[0.02]">
  <!-- Glow decorativo -->
  <div class="absolute top-1/2 -right-40 w-[600px] h-[600px] bg-primary-600/10 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <!-- Coluna de Imagem -->
      <div class="relative group order-2 lg:order-1">
        <div class="absolute inset-0 bg-gradient-to-tr from-primary-600/20 to-accent-500/20 rounded-[2.5rem] transform group-hover:scale-105 transition-transform duration-700 blur border border-white/5"></div>
        <img 
          src={image} 
          alt={title} 
          class="relative rounded-[2rem] border border-white/10 shadow-2xl w-full h-[600px] object-cover filter grayscale-[30%] group-hover:grayscale-0 transition-all duration-700"
        />
        <!-- Glass Badge Flutuante -->
        <div class="absolute -bottom-8 lg:-bottom-8 -right-4 lg:-right-8 bg-black/60 backdrop-blur-2xl p-6 rounded-2xl shadow-2xl border border-white/10 max-w-[220px] transform group-hover:-translate-y-2 transition-transform duration-500">
          <div class="flex items-center gap-3 mb-2">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Destaque</span>
          </div>
          <p class="text-sm font-medium text-slate-200 leading-snug">{badgeText}</p>
        </div>
      </div>

      <!-- Coluna de Texto -->
      <div class="order-1 lg:order-2">
        <h2 class="text-4xl md:text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white to-slate-400 tracking-tight leading-[1.15] mb-12">{title}</h2>
        
        <div class="space-y-6">
          {items.map((item, index) => (
            <div class="group flex gap-6 p-6 rounded-3xl bg-white/[0.02] border border-white/[0.02] hover:bg-white/[0.04] hover:border-white/10 transition-all duration-300">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-white/[0.06] border border-white/15 text-white flex items-center justify-center font-semibold text-lg group-hover:bg-primary-500 group-hover:text-white group-hover:border-primary-400 transition-colors">
                {String(index + 1).padStart(2, '0')}
              </div>
              <div>
                <h3 class="text-xl font-semibold text-slate-200 mb-2">{item.title}</h3>
                <p class="text-slate-500 leading-relaxed font-light">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
