---
interface Props {
  title: string;
  subtitle: string;
  btnText: string;
  btnLink: string;
  bgImage: string;
  titleSize?: string;
}

const { title, subtitle, btnText, btnLink, bgImage, titleSize = 'xlarge' } = Astro.props;

// Mapeamento cravado p/ evitar que o PurgeCSS do Vercel mate as classes dinâmicas
const sizeMap: Record<string, string> = {
  small: 'text-4xl md:text-5xl',
  normal: 'text-5xl md:text-6xl',
  large: 'text-6xl md:text-7xl',
  xlarge: 'text-6xl md:text-8xl', // default base orginal
  giant: 'text-7xl md:text-[7rem]'
};

const selectedTitleSize = sizeMap[titleSize] || sizeMap['xlarge'];
---

<section class="relative min-h-screen flex items-center pt-24 pb-0 px-4 overflow-hidden bg-[#050505]">
  <!-- Grid Background Pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808010_1px,transparent_1px),linear-gradient(to_bottom,#80808010_1px,transparent_1px)] bg-[size:32px_32px]"></div>

  <!-- Glow esquerdo -->
  <div class="absolute top-1/2 -left-40 -translate-y-1/2 w-[600px] h-[600px] bg-primary-600/15 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto w-full relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center min-h-screen">
    
    <!-- Coluna esquerda: texto -->
    <div class="py-20 lg:py-0">
      <!-- Pill Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/[0.03] border border-white/10 text-slate-300 text-xs font-semibold tracking-wide uppercase mb-10 backdrop-blur-md">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
        </span>
        Uma nova experiência
      </div>

      <!-- Título -->
      <h1 class={`${selectedTitleSize} font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-white via-slate-200 to-slate-500 tracking-tighter mb-8 leading-[1.05]`}>
        {title}
      </h1>

      <!-- Subtítulo -->
      <p class="text-lg text-slate-400 mb-12 leading-relaxed font-light max-w-lg">
        {subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a href={btnLink} class="group px-8 py-3.5 rounded-full bg-white text-slate-900 font-bold text-sm hover:scale-105 transition-all shadow-[0_0_40px_-10px_rgba(255,255,255,0.3)] hover:shadow-[0_0_60px_-15px_rgba(255,255,255,0.5)] flex items-center gap-2">
          <span>{btnText}</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
        <a href="#posts" class="px-8 py-3.5 rounded-full bg-white/[0.03] border border-white/10 text-slate-300 font-semibold text-sm hover:bg-white/[0.08] transition-colors flex items-center gap-2">
          Ver artigos
        </a>
      </div>
    </div>

    <!-- Coluna direita: imagem -->
    <div class="relative h-[500px] lg:h-screen hidden lg:flex items-center">
      <!-- Borda com glow -->
      <div class="absolute inset-4 rounded-[2.5rem] border border-white/[0.06] pointer-events-none z-20"></div>
      <!-- Overlay gradiente na base -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent z-10"></div>
      <!-- Overlay lateral esquerdo -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#050505] via-transparent to-transparent z-10"></div>
      <!-- Imagem -->
      <img
        src={bgImage}
        alt={title}
        class="w-full h-full object-cover filter grayscale-[20%] opacity-70"
        style="border-radius: 0"
      />
      <!-- Linha decorativa vertical esquerda -->
      <div class="absolute left-0 top-0 h-full w-px bg-gradient-to-b from-transparent via-white/10 to-transparent z-20"></div>
    </div>

  </div>
</section>

<style>
  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
  .animate-shimmer {
    animation: shimmer 2s infinite;
  }
</style>
