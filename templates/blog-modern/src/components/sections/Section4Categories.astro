---
import * as LucideIcons from 'lucide-react';

interface Category {
  title: string;
  desc: string;
  icon?: string;
  link: string;
}

interface Props {
  title: string;
  items: Category[];
}

const { title, items = [] } = Astro.props;
---

<section class="py-32 px-4 bg-[#0A0A0A] relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-[#050505] to-[#0A0A0A]"></div>
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-primary-500/20 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Header da seção -->
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between mb-16 gap-6">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/[0.03] border border-white/10 text-slate-400 text-xs font-semibold uppercase tracking-wider mb-6 backdrop-blur-sm">
          <LucideIcons.LayoutGrid size={14} />
          <span>Tópicos</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-b from-white to-slate-400 tracking-tight">{title}</h2>
      </div>
      <p class="text-slate-500 text-sm font-light max-w-xs leading-relaxed md:text-right">Explore nosso conteúdo organizado por tema.</p>
    </div>

    <!-- Bento Grid: 1 card grande + demais menores -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {items.length > 0 && (() => {
        const [first, ...rest] = items;
        const FirstIcon = (LucideIcons as any)[first.icon || 'Tag'] || LucideIcons.Tag;
        return (
          <>
            {/* Card destaque — ocupa largura total */}
            <a href={first.link} class="group md:col-span-2 relative p-10 rounded-3xl bg-white/[0.02] border border-white/[0.05] hover:bg-white/[0.04] hover:border-white/10 transition-all duration-500 overflow-hidden flex flex-col md:flex-row items-start md:items-center gap-8">
              <div class="absolute inset-0 bg-gradient-to-r from-primary-600/0 via-primary-600/0 to-primary-600/5 group-hover:to-primary-600/10 transition-colors pointer-events-none"></div>
              <div class="relative z-10 flex-shrink-0 w-16 h-16 rounded-2xl bg-white/[0.04] border border-white/10 flex items-center justify-center text-slate-200 group-hover:text-primary-400 group-hover:border-primary-500/30 group-hover:scale-110 transition-all duration-500">
                <FirstIcon size={30} strokeWidth={1.5} />
              </div>
              <div class="relative z-10 flex-1">
                <h3 class="text-2xl md:text-3xl font-bold text-slate-200 mb-2 group-hover:text-white transition-colors">{first.title}</h3>
                <p class="text-slate-500 leading-relaxed font-light max-w-2xl">{first.desc}</p>
              </div>
              <div class="relative z-10 flex-shrink-0 flex items-center text-sm font-semibold text-slate-500 group-hover:text-primary-400 transition-colors gap-2">
                Explorar
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
              </div>
            </a>

            {/* Cards menores */}
            {rest.map((item, index) => {
              const Icon = (LucideIcons as any)[item.icon || 'Tag'] || LucideIcons.Tag;
              const isFullWidth = rest.length % 2 !== 0 && index === rest.length - 1;
              return (
                <a href={item.link} class={`group relative p-8 rounded-3xl bg-white/[0.02] border border-white/[0.05] hover:bg-white/[0.04] hover:border-white/10 transition-all duration-500 overflow-hidden ${isFullWidth ? 'md:col-span-2' : ''}`}>
                  <div class="absolute inset-0 bg-gradient-to-br from-accent-500/0 to-accent-500/5 group-hover:to-accent-500/10 transition-colors pointer-events-none"></div>
                  <div class="relative z-10">
                    <div class="mb-6 w-12 h-12 rounded-xl bg-white/[0.03] border border-white/10 flex items-center justify-center text-slate-400 group-hover:text-accent-400 group-hover:border-accent-500/30 group-hover:scale-110 transition-all duration-500">
                      <Icon size={22} strokeWidth={1.5} />
                    </div>
                    <h3 class="text-xl font-bold text-slate-200 mb-2 group-hover:text-white transition-colors">{item.title}</h3>
                    <p class="text-slate-500 text-sm line-clamp-2 leading-relaxed font-light mb-6">{item.desc}</p>
                    <span class="inline-flex items-center text-xs font-semibold text-slate-500 group-hover:text-accent-400 transition-colors gap-1.5">
                      Ver artigos
                      <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                    </span>
                  </div>
                </a>
              );
            })}
          </>
        );
      })()}
    </div>
  </div>
</section>
