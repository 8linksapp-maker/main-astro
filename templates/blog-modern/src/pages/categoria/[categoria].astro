---
import BaseLayout from '../../layouts/BaseLayout.astro';
import categoriesData from '../../data/categories.json';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
  const categoriesFromPosts = [...new Set(posts.map(post => post.data.category).filter(Boolean))];
  const allCategories = [...new Set([...finalCategoriesData, ...categoriesFromPosts])];

  return allCategories.map(category => ({
    params: { categoria: category.toLowerCase().replace(/[^a-z0-9]/g, '-') },
    props: { 
        category, 
        posts: posts.filter(p => (p.data.category || '').toLowerCase() === category.toLowerCase()).sort((a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0)) 
    }
  }));
}

const { category, posts } = Astro.props;
const [featured, ...rest] = posts;
---

<BaseLayout title={`Blog - ${category}`} description={`Artigos e novidades na categoria ${category}`}>
  <div class="bg-[#050505] min-h-screen">

    <!-- Header editorial: mesma estrutura que o blog/index -->
    <header class="pt-40 pb-16 px-4 border-b border-white/[0.04] relative overflow-hidden">
      <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-accent-600/10 rounded-full blur-[150px] pointer-events-none"></div>
      <div class="max-w-7xl mx-auto relative z-10 flex flex-col md:flex-row items-end justify-between gap-8">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 text-white text-xs font-semibold uppercase tracking-wider mb-6 backdrop-blur-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-500"></span>
            Categoria
          </div>
          <h1 class="text-5xl md:text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-white to-slate-500 tracking-tighter leading-[0.95]">
            {category}
          </h1>
        </div>
        <div class="flex items-end flex-col gap-3">
          <p class="text-slate-500 font-light text-sm">{posts.length} {posts.length === 1 ? 'artigo' : 'artigos'} nesta categoria</p>
          <a href="/blog" class="inline-flex items-center gap-1.5 text-slate-500 hover:text-white text-xs font-semibold uppercase tracking-wider transition-colors">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Todos os artigos
          </a>
        </div>
      </div>
    </header>

    <div class="max-w-7xl mx-auto px-4 py-20 relative z-10">
      {posts.length === 0 ? (
        <div class="text-center py-32">
          <div class="w-16 h-16 rounded-full bg-white/[0.03] border border-white/10 flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          </div>
          <p class="text-slate-500 font-light">Nenhum artigo publicado nesta categoria ainda.</p>
          <a href="/blog" class="mt-6 inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-white/[0.03] border border-white/10 text-slate-300 text-sm font-semibold hover:bg-white/[0.06] transition-all">Ver todos os artigos</a>
        </div>
      ) : (
        <>
          {/* Post destaque */}
          {featured && (
            <article class="group mb-16 relative bg-[#111111] rounded-3xl overflow-hidden border border-white/[0.05] hover:border-white/10 transition-all duration-500 shadow-2xl shadow-black/50">
              <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr]">
                <a href={`/blog/${featured.slug}`} class="block relative overflow-hidden bg-[#1A1A1A] lg:h-[420px]">
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[#111111] z-10 hidden lg:block"></div>
                  <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors z-20 duration-500"></div>
                  <img src={featured.data.heroImage || 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f'} alt={featured.data.title} class="w-full h-full object-cover aspect-[4/3] lg:aspect-auto filter grayscale-[20%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
                </a>
                <div class="p-10 lg:p-14 flex flex-col justify-between">
                  <div>
                    <div class="flex items-center gap-3 mb-8">
                      <span class="px-3 py-1 rounded-md bg-white/[0.08] border border-white/15 text-white font-bold text-[10px] uppercase tracking-widest">Destaque</span>
                      <span class="px-3 py-1 rounded-md bg-white/[0.08] border border-white/15 text-white font-bold text-[10px] uppercase tracking-widest">{featured.data.category}</span>
                    </div>
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-100 mb-6 group-hover:text-white transition-colors leading-snug">
                      <a href={`/blog/${featured.slug}`}>{featured.data.title}</a>
                    </h2>
                    <p class="text-slate-500 leading-relaxed font-light line-clamp-3">{featured.data.description}</p>
                  </div>
                  <div class="flex items-center justify-between mt-10 pt-8 border-t border-white/[0.05]">
                    <span class="text-slate-600 text-xs uppercase tracking-wider">{featured.data.pubDate ? new Date(featured.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) : ''}</span>
                    <a href={`/blog/${featured.slug}`} class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-white/[0.05] border border-white/10 text-slate-200 text-sm font-semibold hover:bg-white/[0.1] hover:text-white transition-all group/btn">
                      Ler artigo
                      <svg class="w-4 h-4 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                    </a>
                  </div>
                </div>
              </div>
            </article>
          )}

          {/* Divisor */}
          {rest.length > 0 && (
            <div class="flex items-center gap-6 mb-12">
              <div class="flex-1 h-px bg-white/[0.04]"></div>
              <span class="text-slate-600 text-xs uppercase tracking-widest font-semibold shrink-0">Mais artigos</span>
              <div class="flex-1 h-px bg-white/[0.04]"></div>
            </div>
          )}

          {/* Lista editorial dos demais */}
          <div class="space-y-0 divide-y divide-white/[0.04]">
            {rest.map((post, i) => (
              <article class="group grid grid-cols-[auto_1fr_auto] gap-8 py-8 items-center hover:bg-white/[0.01] transition-colors px-4 -mx-4 rounded-2xl">
                <span class="text-2xl font-black text-white/[0.06] font-mono w-10 text-right shrink-0 group-hover:text-white/[0.12] transition-colors">{String(i + 2).padStart(2, '0')}</span>
                <div class="flex items-center gap-6">
                  <a href={`/blog/${post.slug}`} class="flex-shrink-0 w-20 h-20 sm:w-28 sm:h-20 rounded-xl overflow-hidden bg-[#1A1A1A]">
                    <img src={post.data.heroImage || 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f'} alt={post.data.title} class="w-full h-full object-cover filter grayscale-[50%] group-hover:grayscale-0 group-hover:scale-110 transition-all duration-500" />
                  </a>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="text-white text-[10px] font-bold uppercase tracking-widest">{post.data.category}</span>
                    </div>
                    <h2 class="text-base sm:text-xl font-bold text-slate-300 group-hover:text-white transition-colors leading-snug line-clamp-2">
                      <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                    </h2>
                    <p class="text-slate-600 text-sm mt-1 line-clamp-1 font-light hidden sm:block">{post.data.description}</p>
                  </div>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-slate-600 text-xs uppercase tracking-wider mb-3">{post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' }) : ''}</p>
                  <a href={`/blog/${post.slug}`} class="text-primary-400 text-sm font-semibold hidden sm:flex items-center gap-1.5 justify-end group-hover:gap-2.5 transition-all">Ler <span class="group-hover:translate-x-0.5 transition-transform">→</span></a>
                </div>
              </article>
            ))}
          </div>
        </>
      )}
    </div>
  </div>
</BaseLayout>
