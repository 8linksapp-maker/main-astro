---
import BaseLayout from '../layouts/BaseLayout.astro';
import sobreData from '../data/sobre.json';
import siteConfig from '../data/siteConfig.json';
---

<BaseLayout 
  title={sobreData.seo?.title || "Sobre Nós"} 
  description={sobreData.seo?.description}
  image={sobreData.seo?.image}
>
  <div class="bg-[#050505] min-h-screen">

    <!-- Hero: imagem full-width com título por cima (igual ao slug.astro) -->
    <div class="relative w-full h-[55vh] min-h-[380px] overflow-hidden">
      <img src={sobreData.hero.image} alt={sobreData.hero.title} class="w-full h-full object-cover filter grayscale-[30%] scale-105" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#050505]/60 via-transparent to-[#050505]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#050505]/50 to-transparent"></div>
      <div class="absolute top-0 inset-x-0 pt-32 px-8 md:px-16">
        <div class="max-w-7xl mx-auto">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/[0.06] border border-white/15 text-white text-xs font-semibold uppercase tracking-wider backdrop-blur-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-primary-500 animate-pulse"></span>
            Quem Somos
          </span>
        </div>
      </div>
    </div>

    <!-- Conteúdo: layout editorial com sidebar (igual ao [slug].astro) -->
    <div class="max-w-7xl mx-auto px-4 md:px-8 relative -mt-20 z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 xl:gap-20 pb-24">

        <!-- Coluna principal -->
        <main>
          <h1 class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 tracking-tight leading-[1.05] mb-8">
            {sobreData.hero.title}
          </h1>
          <div class="w-full h-px bg-gradient-to-r from-white/10 to-transparent mb-10"></div>

          <div class="prose prose-lg md:prose-xl prose-invert max-w-none
            prose-headings:text-slate-100 prose-headings:font-bold prose-headings:tracking-tight
            prose-p:text-slate-400 prose-p:leading-relaxed prose-p:font-light
            prose-a:text-primary-400 prose-a:no-underline hover:prose-a:underline
            prose-strong:text-slate-200
          ">
            <p>{sobreData.hero.desc}</p>
            <h2>{sobreData.content.missionTitle}</h2>
            <p>{sobreData.content.missionText}</p>
            <h2>{sobreData.content.teamTitle}</h2>
            <p>{sobreData.content.teamText}</p>
          </div>
        </main>

        <!-- Sidebar sticky -->
        <aside class="hidden lg:block">
          <div class="sticky top-32 space-y-4">
            <div class="bg-[#111111] rounded-2xl p-6 border border-white/[0.05] space-y-4">
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Sobre nós</p>
              <p class="text-slate-400 text-sm font-light leading-relaxed">{siteConfig.description}</p>
              <div class="pt-4 border-t border-white/[0.05]">
                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-2">Contato</p>
                <a href={`mailto:${siteConfig.contact.email}`} class="text-primary-400 text-sm hover:underline">{siteConfig.contact.email}</a>
              </div>
            </div>
            <a href="/blog" class="w-full flex items-center justify-center gap-2 py-3 px-6 rounded-xl bg-white/[0.02] border border-white/[0.05] text-slate-400 text-sm font-semibold hover:bg-white/[0.05] hover:text-white transition-all group">
              <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Ver artigos
            </a>
          </div>
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
