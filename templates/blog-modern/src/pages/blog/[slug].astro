---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import authorsData from '../../data/authors.json';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
const post = Astro.props;
const { Content } = await post.render();

const currentAuthor = authorsData.find((a: any) => a.id === post.data.author) || authorsData[0] || {
  name: post.data.author || 'Equipe',
  role: 'Redação',
  avatar: '',
  bio: ''
};
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.heroImage} type="article">
  <div class="bg-[#050505] min-h-screen">

    <!-- Hero image: full-width com overlay e título por cima -->
    <div class="relative w-full h-[60vh] min-h-[400px] overflow-hidden">
      <!-- Imagem -->
      {post.data.heroImage && (
        <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover filter grayscale-[20%] scale-105" />
      )}
      <!-- Overlays -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#050505]/60 via-transparent to-[#050505]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#050505]/40 to-transparent"></div>

      <!-- Metadados sobre a imagem: categoria + data -->
      <div class="absolute top-0 inset-x-0 pt-32 px-8 md:px-16">
        <div class="max-w-7xl mx-auto flex items-center gap-3">
          <a href="/blog" class="inline-flex items-center gap-1.5 text-slate-400 hover:text-white text-xs font-semibold uppercase tracking-wider transition-colors">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Blog
          </a>
          <span class="text-white/20 text-xs">·</span>
          <span class="px-2.5 py-1 rounded-md bg-white/[0.08] border border-white/15 text-white font-bold text-[10px] uppercase tracking-widest backdrop-blur-sm">{post.data.category}</span>
        </div>
      </div>
    </div>

    <!-- Conteúdo principal: layout editorial com sidebar -->
    <div class="max-w-7xl mx-auto px-4 md:px-8 relative -mt-24 z-10">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12 xl:gap-20">

        <!-- Coluna principal de conteúdo -->
        <main>
          <!-- Cabeçalho do artigo -->
          <div class="mb-12">
            <h1 class="text-4xl md:text-5xl xl:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 tracking-tight leading-[1.05] mb-8">
              {post.data.title}
            </h1>
            <!-- Meta bar -->
            <div class="flex flex-wrap items-center gap-4 pb-8 border-b border-white/[0.06]">
              <div class="flex items-center gap-3">
                {currentAuthor.avatar ? (
                  <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-9 h-9 rounded-full object-cover border border-white/10" />
                ) : (
                  <div class="w-9 h-9 rounded-full bg-white/[0.05] border border-white/10 flex items-center justify-center text-sm font-bold text-slate-300">{currentAuthor.name.charAt(0)}</div>
                )}
                <span class="text-slate-300 font-medium text-sm">{currentAuthor.name}</span>
              </div>
              <span class="text-white/10 hidden sm:block">·</span>
              <span class="text-slate-500 text-sm">{post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</span>
            </div>
          </div>

          <!-- Corpo do artigo -->
          <div class="prose prose-lg md:prose-xl prose-invert max-w-none
            prose-headings:text-slate-100 prose-headings:font-bold prose-headings:tracking-tight
            prose-p:text-slate-400 prose-p:leading-relaxed prose-p:font-light
            prose-a:text-primary-400 prose-a:no-underline hover:prose-a:underline
            prose-strong:text-slate-200 prose-strong:font-semibold
            prose-blockquote:border-l-primary-500 prose-blockquote:text-slate-400 prose-blockquote:bg-white/[0.02] prose-blockquote:rounded-r-xl prose-blockquote:py-1
            prose-code:text-accent-400 prose-code:bg-white/[0.04] prose-code:rounded prose-code:px-1.5
          ">
            <Content />
          </div>
        </main>

        <!-- Sidebar: sticky -->
        <aside class="hidden lg:block">
          <div class="sticky top-32 space-y-6">

            <!-- Card do autor -->
            <div class="bg-[#111111] rounded-2xl p-6 border border-white/[0.05] relative overflow-hidden group hover:border-white/10 transition-colors">
              <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 mb-5">Autor</p>
              <div class="flex items-center gap-4 mb-5">
                {currentAuthor.avatar ? (
                  <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-14 h-14 rounded-full object-cover border border-white/10 shrink-0" />
                ) : (
                  <div class="w-14 h-14 rounded-full bg-white/[0.03] border border-white/10 flex items-center justify-center text-xl font-bold text-slate-300 shrink-0">{currentAuthor.name.charAt(0)}</div>
                )}
                <div>
                  <p class="font-bold text-slate-200 text-sm">{currentAuthor.name}</p>
                  {currentAuthor.role && <p class="text-primary-400 text-xs font-semibold uppercase tracking-wider mt-0.5">{currentAuthor.role}</p>}
                </div>
              </div>
              <p class="text-slate-500 text-sm leading-relaxed font-light">{currentAuthor.bio}</p>
            </div>

            <!-- Card de metadados do artigo -->
            <div class="bg-[#111111] rounded-2xl p-6 border border-white/[0.05] space-y-5">
              <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Sobre este artigo</p>
              <div class="space-y-3">
                <div class="flex items-start justify-between gap-2">
                  <span class="text-slate-600 text-xs uppercase tracking-wider">Categoria</span>
                  <span class="px-2 py-0.5 rounded bg-white/[0.08] border border-white/15 text-white text-[10px] font-bold uppercase tracking-widest">{post.data.category}</span>
                </div>
                <div class="flex items-start justify-between gap-2 pt-3 border-t border-white/[0.04]">
                  <span class="text-slate-600 text-xs uppercase tracking-wider">Publicado em</span>
                  <span class="text-slate-400 text-xs font-medium">{post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}</span>
                </div>
              </div>
            </div>

            <!-- Voltar ao blog -->
            <a href="/blog" class="w-full flex items-center justify-center gap-2 py-3 px-6 rounded-xl bg-white/[0.02] border border-white/[0.05] text-slate-400 text-sm font-semibold hover:bg-white/[0.05] hover:text-white transition-all group">
              <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Voltar para Artigos
            </a>

          </div>
        </aside>
      </div>

      <!-- Rodapé mobile: voltar -->
      <div class="lg:hidden mt-16 pt-8 border-t border-white/[0.05] flex justify-center">
        <a href="/blog" class="px-8 py-3 rounded-full bg-white/[0.03] border border-white/10 text-slate-300 font-semibold text-sm hover:bg-white/[0.08] hover:text-white transition-all flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          Voltar para Artigos
        </a>
      </div>

      <div class="pb-24"></div>
    </div>

  </div>
</BaseLayout>
