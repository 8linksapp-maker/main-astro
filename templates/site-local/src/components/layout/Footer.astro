---
import siteConfig from '../../data/siteConfig.json';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
---

<footer class="bg-slate-50 border-t border-slate-200 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="md:col-span-1">
        <a href="/" class="text-xl font-bold text-slate-900 mb-6 block">
          {siteConfig.contact.name}
        </a>
        <p class="text-slate-600 max-w-sm text-sm">
          {siteConfig.description}
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-slate-900 mb-6">Nossos Serviços</h4>
        <ul class="space-y-4 text-slate-600 text-sm">
          {services.slice(0, 5).map(service => (
            <li><a href={`/servicos/${service.id.replace('.md', '')}`} class="hover:text-primary-600 transition-colors">{service.data.title}</a></li>
          ))}
          <li><a href="/servicos" class="font-bold text-primary-600 mt-2 block">Ver todos →</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-slate-900 mb-6">Links Rápidos</h4>
        <ul class="space-y-4 text-slate-600 text-sm">
          <li><a href="/" class="hover:text-primary-600 transition-colors">Home</a></li>
          {siteConfig.enableBlog && <li><a href="/blog" class="hover:text-primary-600 transition-colors">Blog</a></li>}
          <li><a href="/sobre" class="hover:text-primary-600 transition-colors">Sobre Nós</a></li>
          <li><a href="/contato" class="hover:text-primary-600 transition-colors">Página de Contato</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-slate-900 mb-6">Contato</h4>
        <ul class="space-y-4 text-slate-600 text-sm">
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            {siteConfig.contact.phone}
          </li>
          <li>{siteConfig.contact.email}</li>
          <li>{siteConfig.contact.address}</li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-200 text-center">
      <p class="text-slate-500 text-xs">
        &copy; {new Date().getFullYear()} {siteConfig.contact.name}. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
