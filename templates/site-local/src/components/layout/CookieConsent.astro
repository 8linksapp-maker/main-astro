---
---
<div id="cookie-banner" class="fixed bottom-8 left-8 right-8 md:left-auto md:max-w-md z-[100] transform translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
  <div class="bg-slate-900 text-white p-6 rounded-[2rem] shadow-2xl border border-white/10 backdrop-blur-xl">
    <div class="flex items-start gap-4 mb-6">
      <div class="w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
      </div>
      <div>
        <h4 class="font-bold text-lg mb-1">Privacidade e Cookies</h4>
        <p class="text-slate-400 text-sm leading-relaxed">
          Utilizamos cookies para melhorar sua experiência e analisar o tráfego do nosso site. Ao clicar em "Aceitar", você concorda com nossa política.
        </p>
      </div>
    </div>
    <div class="flex gap-4">
      <button id="accept-cookies" class="flex-1 px-6 py-3 rounded-xl bg-primary-600 hover:bg-primary-500 text-white font-bold transition-all shadow-lg shadow-primary-500/20">
        Aceitar Tudo
      </button>
      <a href="/privacidade" class="flex-1 px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 text-white font-bold text-center transition-all border border-white/10">
        Ler Política
      </a>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('accept-cookies');

  if (banner && acceptBtn) {
    // Verificar se já aceitou
    if (!localStorage.getItem('cookies-accepted')) {
      setTimeout(() => {
        banner.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
      }, 2000);
    }

    acceptBtn.addEventListener('click', () => {
      localStorage.setItem('cookies-accepted', 'true');
      banner.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
    });
  }
</script>
