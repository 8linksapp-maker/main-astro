---
interface Props {
  tag: string;
  title: string;
  desc: string;
  image: string;
  btnText: string;
  btnLink: string;
  miniCards: string[];
}

const { tag, title, desc, image, btnText, btnLink, miniCards } = Astro.props;
---

<section class="py-32 px-4 bg-slate-50 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
      <div class="relative group">
        <div class="absolute -inset-6 bg-primary-100 rounded-[3rem] rotate-3 group-hover:rotate-0 transition-transform duration-500"></div>
        <img src={image} alt={title} class="relative rounded-[2.5rem] shadow-2xl w-full h-[600px] object-cover" />
      </div>

      <div>
        <div class="inline-block px-4 py-1 rounded-full bg-primary-100 text-primary-700 font-bold text-xs uppercase mb-6 tracking-widest">
          {tag}
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-8 tracking-tight leading-tight">{title}</h2>
        <p class="text-xl text-slate-600 leading-relaxed mb-10 font-medium">
          {desc}
        </p>
        
        <div class="grid grid-cols-2 gap-4 mb-12">
          {miniCards.map((card) => (
            <div class="flex items-center gap-3 p-4 rounded-2xl bg-white border border-slate-100 shadow-sm transition-all hover:border-primary-300">
              <div class="w-2 h-2 rounded-full bg-primary-600"></div>
              <span class="font-bold text-slate-700">{card}</span>
            </div>
          ))}
        </div>

        <a href={btnLink} class="inline-flex items-center gap-3 px-8 py-4 rounded-2xl bg-slate-900 text-white font-bold text-lg hover:bg-slate-800 transition-all group">
          {btnText} <span class="group-hover:translate-x-2 transition-transform">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
