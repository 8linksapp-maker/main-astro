---
import siteConfig from '../../data/siteConfig.json';

interface Props {
  title: string;
  desc: string;
  btnSubmitText: string;
}

const { title, desc, btnSubmitText } = Astro.props;
---

<section class="py-32 px-4 bg-white" id="contato">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-stretch">
      <div class="bg-slate-950 text-white p-12 md:p-20 rounded-[3rem] flex flex-col justify-center relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary-600/20 blur-[100px] rounded-full"></div>
        <div class="relative z-10">
          <h2 class="text-4xl md:text-5xl font-black mb-8 tracking-tight leading-tight">{siteConfig.contact.name}</h2>
          <p class="text-xl text-slate-400 mb-12 max-w-md">{desc}</p>
          
          <div class="space-y-8">
            <div class="flex gap-6">
              <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-primary-400 border border-white/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <div>
                <p class="text-slate-500 text-sm uppercase font-bold tracking-widest mb-1">Ligue para nós</p>
                <p class="text-2xl font-bold">{siteConfig.contact.phone}</p>
              </div>
            </div>
            
            <div class="flex gap-6">
              <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-primary-400 border border-white/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <p class="text-slate-500 text-sm uppercase font-bold tracking-widest mb-1">E-mail</p>
                <p class="text-2xl font-bold">{siteConfig.contact.email}</p>
              </div>
            </div>

            <div class="flex gap-6">
              <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-primary-400 border border-white/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div>
                <p class="text-slate-500 text-sm uppercase font-bold tracking-widest mb-1">Localização</p>
                <p class="text-xl font-bold leading-tight">{siteConfig.contact.address}</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-primary-400 border border-white/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <div>
                <p class="text-slate-500 text-sm uppercase font-bold tracking-widest mb-1">Horário de Funcionamento</p>
                <p class="text-sm font-medium">{siteConfig.businessHours.weekdays}</p>
                <p class="text-sm font-medium">{siteConfig.businessHours.saturday}</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col justify-center">
        <h3 class="text-3xl font-black text-slate-900 mb-4 tracking-tight">{title}</h3>
        <p class="text-lg text-slate-600 mb-10">{desc}</p>
        
        <form class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <input type="text" placeholder="Nome Completo" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-200 focus:border-primary-500 focus:bg-white outline-none transition-all font-medium" />
            <input type="email" placeholder="E-mail" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-200 focus:border-primary-500 focus:bg-white outline-none transition-all font-medium" />
          </div>
          <input type="text" placeholder="Assunto" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-200 focus:border-primary-500 focus:bg-white outline-none transition-all font-medium" />
          <textarea placeholder="Como podemos ajudar?" rows="5" class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-200 focus:border-primary-500 focus:bg-white outline-none transition-all font-medium resize-none"></textarea>
          
          <button type="submit" class="w-full py-5 rounded-2xl bg-primary-600 text-white font-bold text-xl hover:bg-primary-500 transition-all shadow-xl shadow-primary-500/30">
            {btnSubmitText}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
