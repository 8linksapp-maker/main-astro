---
interface Testimonial {
  text: string;
  name: string;
  role: string;
  image: string;
}

interface Props {
  tag: string;
  title: string;
  items: Testimonial[];
}

const { tag, title, items } = Astro.props;
---

<section class="py-32 px-4 bg-slate-950 text-white relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary-500/50 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center mb-20">
      <div class="inline-block px-4 py-1 rounded-full bg-primary-600/20 text-primary-400 font-bold text-xs uppercase mb-6 tracking-widest border border-primary-600/30">
        {tag}
      </div>
      <h2 class="text-4xl md:text-6xl font-black mb-8 tracking-tight">{title}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {items.map((testimonial) => (
        <div class="bg-white/5 border border-white/10 p-8 rounded-[2.5rem] flex flex-col justify-between hover:bg-white/10 transition-all">
          <p class="text-lg text-slate-300 italic mb-8 leading-relaxed">"{testimonial.text}"</p>
          <div class="flex items-center gap-4">
            <img src={testimonial.image} alt={testimonial.name} class="w-12 h-12 rounded-full object-cover border-2 border-primary-500" />
            <div>
              <p class="font-bold text-white text-sm">{testimonial.name}</p>
              <p class="text-slate-500 text-xs uppercase tracking-tighter">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
