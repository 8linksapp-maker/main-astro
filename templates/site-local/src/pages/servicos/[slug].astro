---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section6Contact from '../../components/sections/Section6Contact.astro';
import home from '../../data/home.json';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map(entry => ({
    params: { slug: entry.id.replace('.md', '') }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={entry.data.image}>
  <!-- Hero do Serviço -->
  <section class="relative pt-40 pb-24 px-4 bg-slate-950 text-white overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={entry.data.image} alt={entry.data.title} class="w-full h-full object-cover opacity-20 blur-sm" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/50 to-transparent"></div>
    </div>
    
    <div class="max-w-7xl mx-auto relative z-10">
      <nav class="flex mb-8 text-sm font-bold uppercase tracking-widest text-primary-400">
        <a href="/" class="hover:text-white">Home</a>
        <span class="mx-3 text-slate-600">/</span>
        <a href="/servicos" class="hover:text-white">Serviços</a>
        <span class="mx-3 text-slate-600">/</span>
        <span class="text-white">{entry.data.title}</span>
      </nav>
      
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-1 rounded-full bg-primary-600/30 text-primary-400 font-bold text-xs uppercase mb-6 tracking-widest border border-primary-600/30">
          {entry.data.tag}
        </div>
        <h1 class="text-5xl md:text-8xl font-black mb-8 tracking-tight leading-[0.9]">{entry.data.title}</h1>
        <p class="text-xl md:text-2xl text-slate-400 font-medium leading-relaxed max-w-3xl">
          {entry.data.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Conteúdo do Serviço -->
  <section class="py-24 px-4 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-20">
      <!-- Coluna Principal -->
      <div class="lg:col-span-2">
        {entry.data.gallery && (
          <div class="mb-16">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {entry.data.gallery.map((img) => (
                <div class="group relative aspect-[4/3] overflow-hidden rounded-[2rem] bg-slate-100 shadow-lg border border-slate-100">
                  <img src={img} alt="Galeria" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                  <div class="absolute inset-0 bg-primary-600/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                </div>
              ))}
            </div>
          </div>
        )}

        <article class="prose prose-xl prose-slate prose-primary max-w-none prose-headings:font-black prose-headings:tracking-tight prose-p:text-slate-600 prose-p:leading-relaxed">
          <Content />
        </article>

        {entry.data.highlights && (
          <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 gap-6">
            {entry.data.highlights.map((item) => (
              <div class="flex items-center gap-4 p-8 rounded-3xl bg-slate-50 border border-slate-100 hover:border-primary-300 transition-all group">
                <div class="w-12 h-12 rounded-2xl bg-primary-600 text-white flex items-center justify-center shadow-lg shadow-primary-500/20 group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-lg font-bold text-slate-800">{item}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-10">
        <div class="sticky top-32">
          <div class="p-10 rounded-[2.5rem] bg-slate-900 text-white shadow-2xl relative overflow-hidden">
             <div class="absolute top-0 right-0 w-32 h-32 bg-primary-600/20 blur-[60px] rounded-full"></div>
             <h3 class="text-2xl font-black mb-6 relative z-10">Solicite um Orçamento</h3>
             <p class="text-slate-400 mb-8 relative z-10 leading-relaxed font-medium">Fale agora com um especialista e tire suas dúvidas sobre {entry.data.title}.</p>
             <a href={home.hero.btnWhatsappLink} target="_blank" rel="noopener" class="block w-full py-5 rounded-2xl bg-primary-600 text-white font-bold text-center text-lg hover:bg-primary-500 transition-all shadow-xl shadow-primary-500/30">
               WhatsApp Direto
             </a>
             <div class="mt-8 pt-8 border-t border-white/10 text-center">
                <p class="text-slate-500 text-sm font-bold uppercase tracking-widest mb-2">ou ligue para</p>
                <p class="text-xl font-bold">{home.contact?.phone || '(11) 9999-9999'}</p>
             </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- Seção de Contato Global -->
  <Section6Contact {...home.contact} />
</BaseLayout>
