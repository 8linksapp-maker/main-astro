---
import BaseLayout from '../../layouts/BaseLayout.astro';
import servicesData from '../../data/servicesData.json';
---

<BaseLayout title={servicesData.hero.title} description={servicesData.hero.desc}>
  <!-- Hero Section (Mini) -->
  <section class="pt-32 pb-20 px-4 bg-slate-50">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block px-4 py-1 rounded-full bg-primary-100 text-primary-700 font-bold text-xs uppercase mb-6 tracking-widest">
        {servicesData.hero.tag}
      </div>
      <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-8 tracking-tight">{servicesData.hero.title}</h1>
      <p class="text-xl text-slate-600 font-medium leading-relaxed">
        {servicesData.hero.desc}
      </p>
    </div>
  </section>

  <!-- Services List -->
  <section class="py-24 px-4 bg-white">
    <div class="max-w-7xl mx-auto space-y-32">
      {servicesData.services.map((service, index) => (
        <div class={`grid grid-cols-1 md:grid-cols-2 gap-16 items-center ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
          <div class={`relative group ${index % 2 !== 0 ? 'md:order-2' : ''}`}>
            <div class="absolute -inset-4 bg-slate-100 rounded-[2.5rem] rotate-2 group-hover:rotate-0 transition-transform duration-500"></div>
            <img 
              src={service.image} 
              alt={service.title} 
              class="relative rounded-[2rem] shadow-2xl w-full h-[450px] object-cover"
            />
          </div>

          <div class={index % 2 !== 0 ? 'md:order-1' : ''}>
            <div class="inline-block px-3 py-1 rounded-lg bg-primary-100 text-primary-700 font-bold text-[10px] uppercase tracking-wider mb-6">
              {service.tag}
            </div>
            <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-6 tracking-tight leading-tight">{service.title}</h2>
            <p class="text-lg text-slate-600 mb-10 leading-relaxed font-medium">
              {service.desc}
            </p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
              {service.highlights.map((item) => (
                <div class="flex items-center gap-3 p-3 rounded-xl bg-slate-50 border border-slate-100">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-sm font-bold text-slate-700">{item}</span>
                </div>
              ))}
            </div>

            <a href={service.link} class="inline-flex items-center gap-3 px-8 py-4 rounded-2xl bg-slate-900 text-white font-bold hover:bg-slate-800 transition-all group">
              Detalhes do Serviço <span class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-32 px-4 bg-slate-950 text-white overflow-hidden relative">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary-500/30 to-transparent"></div>
    <div class="max-w-4xl mx-auto relative z-10">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-5xl font-black mb-8 tracking-tight">{servicesData.faq.title}</h2>
      </div>

      <div class="space-y-6">
        {servicesData.faq.items.map((item) => (
          <div class="bg-white/5 border border-white/10 p-8 rounded-[2rem] hover:bg-white/10 transition-all">
            <h3 class="text-xl font-bold mb-4">{item.question}</h3>
            <p class="text-slate-400 leading-relaxed">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
