---
import siteConfig from '../../data/siteConfig.json';
---

<footer class="bg-slate-50 border-t border-slate-200 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="md:col-span-2">
        <a href="/" class="flex text-xl font-bold text-slate-900 mb-6 block">
          {siteConfig.logo ? (
            <img src={siteConfig.logo} alt={siteConfig.name} class="h-8 w-auto object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all" />
          ) : (
            siteConfig.name
          )}
        </a>
        <p class="text-slate-600 max-w-sm">
          {siteConfig.description}
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-slate-900 mb-6">Links Rápidos</h4>
        <ul class="space-y-4 text-slate-600 text-sm">
          <li><a href="/" class="hover:text-primary-600 transition-colors">Home</a></li>
          <li><a href="/blog" class="hover:text-primary-600 transition-colors">Blog</a></li>
          <li><a href="/sobre" class="hover:text-primary-600 transition-colors">Sobre Nós</a></li>
          <li><a href="/contato" class="hover:text-primary-600 transition-colors">Página de Contato</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-slate-900 mb-6">Legal</h4>
        <ul class="space-y-4 text-slate-600 text-sm">
          <li><a href="/termos" class="hover:text-primary-600 transition-colors">Termos de Uso</a></li>
          <li><a href="/privacidade" class="hover:text-primary-600 transition-colors">Privacidade</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-200 flex flex-col md:flex-row justify-between items-center gap-4 text-slate-500 text-sm">
      <p>&copy; {new Date().getFullYear()} {siteConfig.author}. Todos os direitos reservados.</p>
      <div class="flex gap-6">
        {siteConfig.social?.instagram && <a href={siteConfig.social.instagram} target="_blank" rel="noopener" class="hover:text-primary-600 transition-colors font-bold">Instagram</a>}
        {siteConfig.social?.facebook && <a href={siteConfig.social.facebook} target="_blank" rel="noopener" class="hover:text-primary-600 transition-colors font-bold">Facebook</a>}
        {siteConfig.social?.twitter && <a href={siteConfig.social.twitter} target="_blank" rel="noopener" class="hover:text-primary-600 transition-colors font-bold">Twitter</a>}
        {siteConfig.social?.linkedin && <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="hover:text-primary-600 transition-colors font-bold">LinkedIn</a>}
        {siteConfig.social?.github && <a href={siteConfig.social.github} target="_blank" rel="noopener" class="hover:text-primary-600 transition-colors font-bold">GitHub</a>}
      </div>
    </div>
  </div>
</footer>
