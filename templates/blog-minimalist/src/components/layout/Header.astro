---
import siteConfig from '../../data/siteConfig.json';
import categoriesData from '../../data/categories.json';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const categoriesFromPosts = [...new Set(posts.map(post => post.data.category).filter(Boolean))];

// Garantir que categoriesData seja um array
const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];

// Prioriza o categories.json, mas mantém compatibilidade com posts antigos se estiver vazio
const allCategories = finalCategoriesData.length > 0 ? finalCategoriesData : categoriesFromPosts;
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
  <nav class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-2xl font-bold">
      {siteConfig.logo ? (
        <img src={siteConfig.logo} alt={siteConfig.name} class="h-8 w-auto object-contain" />
      ) : (
        <span class="bg-gradient-to-r from-primary-600 to-primary-500 bg-clip-text text-transparent">{siteConfig.name}</span>
      )}
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a href="/" class="text-sm font-medium hover:text-primary-600 transition-colors">Home</a>
      
      <div class="relative group">
        <a href="/blog" class="text-sm font-medium hover:text-primary-600 transition-colors flex items-center gap-1">
          Blog
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </a>
        <div class="absolute top-full left-0 pt-4 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-white rounded-xl shadow-xl border border-slate-100 flex flex-col py-2 overflow-hidden">
            <a href="/blog" class="px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-primary-600 font-medium">Todos os Artigos</a>
            {allCategories.map((cat) => (
              <a href={`/categoria/${cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}`} class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-primary-600">{cat}</a>
            ))}
          </div>
        </div>
      </div>
      <a href="/sobre" class="text-sm font-medium hover:text-primary-600 transition-colors">Sobre</a>
      <a href="/contato" class="text-sm font-medium hover:text-primary-600 transition-colors">Contato</a>
    </div>

    <div class="flex items-center gap-4">
      <a href="/contato" class="hidden sm:inline-flex px-5 py-2.5 rounded-full bg-primary-600 text-white text-sm font-semibold hover:bg-primary-700 transition-all shadow-lg shadow-primary-500/20">
        Falar Conosco
      </a>
      <!-- Hamburguer simplificado para Mobile -->
      <button class="md:hidden p-2 text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </nav>
</header>
