---
interface Differentiator {
  title: string;
  desc: string;
}

interface Props {
  title: string;
  image: string;
  badgeText?: string;
  badgeColor?: string;
  items: Differentiator[];
}

const { title, image, items, badgeText = 'Garantia de Qualidade CNX', badgeColor = '#dbeafe' } = Astro.props;
---

<section class="py-32 px-4 bg-slate-50 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
      <div class="relative group">
        <div class="absolute -inset-6 rounded-[3rem] -rotate-3 group-hover:rotate-0 transition-transform duration-500" style={`background-color: ${badgeColor}`}></div>
        <img 
          src={image} 
          alt={title} 
          class="relative rounded-[2.5rem] shadow-2xl w-full h-[600px] object-cover"
        />
        <div class="absolute bottom-10 right-10 bg-white/90 backdrop-blur-xl p-6 rounded-2xl shadow-xl border border-white/20 max-w-[200px]">
          <p class="text-sm font-bold text-slate-900 leading-tight">{badgeText}</p>
        </div>
      </div>

      <div>
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 mb-10 tracking-tight leading-tight">{title}</h2>
        <div class="space-y-10">
          {items.map((item, index) => (
            <div class="flex gap-6 group">
              <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-primary-600 text-white flex items-center justify-center font-bold text-xl shadow-lg shadow-primary-500/30 group-hover:scale-110 transition-transform">
                0{index + 1}
              </div>
              <div>
                <h3 class="text-2xl font-bold text-slate-900 mb-2">{item.title}</h3>
                <p class="text-slate-600 leading-relaxed text-lg">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
