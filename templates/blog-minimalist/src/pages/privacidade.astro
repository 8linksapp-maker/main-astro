---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/siteConfig.json';
import privacyData from '../data/privacy.json';
---

<BaseLayout title={privacyData.title} description={`Leia nossa ${privacyData.title.toLowerCase()} e proteção de dados.`}>
  <section class="py-24 px-4 bg-white">
    <div class="max-w-3xl mx-auto prose prose-lg prose-slate prose-primary">
      <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-8 tracking-tight">{privacyData.title}</h1>
      <p class="text-slate-500 mb-12">Última atualização: {privacyData.lastUpdated || siteConfig.legal.privacy_last_updated}</p>

      {privacyData.content.map((section) => (
        <div>
          <h2>{section.title}</h2>
          <p>{section.text}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
