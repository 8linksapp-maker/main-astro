---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../data/siteConfig.json';
import termsData from '../data/terms.json';
---

<BaseLayout title={termsData.title} description={`Leia nossos ${termsData.title.toLowerCase()} e condições.`}>
  <section class="py-24 px-4 bg-white">
    <div class="max-w-3xl mx-auto prose prose-lg prose-slate prose-primary">
      <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-8 tracking-tight">{termsData.title}</h1>
      <p class="text-slate-500 mb-12">Última atualização: {termsData.lastUpdated || siteConfig.legal.terms_last_updated}</p>

      {termsData.content.map((section) => (
        <div>
          <h2>{section.title}</h2>
          <p>{section.text}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
