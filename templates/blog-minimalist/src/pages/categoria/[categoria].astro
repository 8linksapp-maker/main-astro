---
import BaseLayout from '../../layouts/BaseLayout.astro';
import categoriesData from '../../data/categories.json';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Mapeia todas as categorias do categories.json + as que porventura já existam em posts antigos
  const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
  const categoriesFromPosts = [...new Set(posts.map(post => post.data.category).filter(Boolean))];
  const allCategories = [...new Set([...finalCategoriesData, ...categoriesFromPosts])];

  return allCategories.map(category => ({
    params: { categoria: category.toLowerCase().replace(/[^a-z0-9]/g, '-') },
    props: { 
        category, 
        posts: posts.filter(p => (p.data.category || '').toLowerCase() === category.toLowerCase()).sort((a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0)) 
    }
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`Blog - ${category}`} description={`Artigos e novidades na categoria ${category}`}>
  <section class="py-24 px-4 bg-slate-50 min-h-[60vh]">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 text-center">
        <p class="text-primary-600 font-semibold tracking-wider uppercase text-sm mb-4">CATEGORIA</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900">
          {category}
        </h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.length > 0 ? posts.map((post) => (
          <article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:shadow-md transition-shadow group">
            <a href={`/blog/${post.slug}`}>
              <div class="aspect-video overflow-hidden">
                <img src={post.data.heroImage || 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f'} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
            </a>
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-slate-500 mb-4">
                <span class="px-2 py-0.5 rounded bg-primary-100 text-primary-700 font-medium text-xs uppercase">{post.data.category}</span>
                <span>•</span>
                <span>{post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) : ''}</span>
              </div>
              <h2 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-primary-600 transition-colors">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p class="text-slate-600 text-sm line-clamp-2 mb-6">
                {post.data.description}
              </p>
            </div>
          </article>
        )) : (
            <p class="text-slate-500 col-span-3 text-center">Nenhum post publicado nesta categoria ainda.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
