---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import authorsData from '../../data/authors.json';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
const post = Astro.props;
const { Content } = await post.render();

const currentAuthor = authorsData.find((a: any) => a.id === post.data.author) || authorsData[0] || {
  name: post.data.author || 'Equipe',
  role: 'Redação',
  avatar: '',
  bio: ''
};
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.heroImage} type="article">
  <article class="py-24 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12 text-center">
        <span class="inline-block px-3 py-1 rounded bg-primary-100 text-primary-700 font-bold text-xs uppercase mb-6">
          {post.data.category}
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-8">
          {post.data.title}
        </h1>
        <div class="flex items-center justify-center gap-3 text-slate-500 text-sm">
          <div class="flex items-center gap-2">
            {currentAuthor.avatar ? (
              <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-6 h-6 rounded-full object-cover shadow-sm" />
            ) : (
              <div class="w-6 h-6 rounded-full bg-slate-200 flex items-center justify-center text-[10px] font-bold text-slate-500">{currentAuthor.name.charAt(0)}</div>
            )}
            <span class="font-medium text-slate-700">{currentAuthor.name}</span>
          </div>
          <span>•</span>
          <span>{post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</span>
        </div>
      </div>

      {post.data.heroImage && (
        <img src={post.data.heroImage} alt={post.data.title} class="w-full h-[400px] object-cover rounded-3xl shadow-xl mb-16" />
      )}

      <div class="prose prose-lg prose-slate max-w-none prose-headings:text-slate-900 prose-primary">
        <Content />
      </div>

      <div class="mt-24 pt-12 border-t border-slate-100">
        
        {/* Author Bio Box */}
        <div class="bg-slate-50 rounded-2xl p-6 sm:p-8 flex items-start gap-6 mb-12 border border-slate-100">
          {currentAuthor.avatar ? (
            <img src={currentAuthor.avatar} alt={currentAuthor.name} class="w-20 h-20 rounded-full object-cover shadow-md shrink-0" />
          ) : (
            <div class="w-20 h-20 rounded-full bg-primary-100 flex items-center justify-center text-2xl font-bold text-primary-700 shrink-0">{currentAuthor.name.charAt(0)}</div>
          )}
          <div>
            <h3 class="font-bold text-slate-900 text-lg mb-1">{currentAuthor.name}</h3>
            {currentAuthor.role && <p class="text-primary-600 text-sm font-semibold mb-3">{currentAuthor.role}</p>}
            <p class="text-slate-600 text-sm leading-relaxed">{currentAuthor.bio}</p>
          </div>
        </div>

        <div class="flex justify-between items-center">
          <a href="/blog" class="text-primary-600 font-bold flex items-center gap-2 hover:underline">
            ← Voltar para todos os posts
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
